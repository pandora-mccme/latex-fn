#!/usr/bin/bash
set -euo pipefail

trap 'rm -rf "$WD"' EXIT

WD=$(mktemp -d)
export LANG="ru_RU.UTF8"
cd "$WD"

cat >main.zip
7z x -y main.zip >main.log 2>&1 && pdflatex -file-line-error -interaction=nonstopmode main.tex >>main.log 2>&1
if [ -f main.pdf ];
then
    cat main.pdf;
else
    grep -E "(\.tex:|CLONE|CHAIN|HM)" main.log;
    exit 1;
fi
