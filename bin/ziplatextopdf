#!/usr/bin/bash
set -euo pipefail

trap 'rm -rf "$WD"' EXIT

WD=$(mktemp -d)
cd "$WD"

cat >main.zip
if 7z x -y main.zip >main.log 2>&1 &&
    pdflatex -file-line-error -interactive=nonstopmode main.tex >>main.log 2>&1; then
    cat main.pdf
else
    cat main.log | egrep "(\.tex:|CLONE|CHAIN|HM)"
    exit 1
fi
